---
import Layout from '../../layouts/Layout.astro';
import ExamMode from '../../components/ExamMode.vue';
import questions from '../../data/questions/exam.json';
---

<Layout title="Simulacro de Examen">
  <div class="space-y-12 pb-20">
    <header class="relative overflow-hidden rounded-3xl p-8 md:p-12 bg-surface border border-surface-border shadow-sm">
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-rose-500/10 rounded-full blur-3xl"></div>
      <div class="relative z-10 max-w-2xl">
        <span class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-wider uppercase bg-rose-500/10 text-rose-600 rounded-full">
          Prueba Final
        </span>
        <h1 class="text-4xl md:text-5xl font-black mb-6 leading-tight">
          Simulador de <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-500 to-pink-500">Examen AI-900</span>
        </h1>
        <p class="text-lg text-foreground/70 leading-relaxed">
          Mismo formato, misma dificultad. Prepárate para el examen oficial de Microsoft con este simulacro de 40 preguntas.
        </p>
      </div>
    </header>

    <div class="glass p-8 md:p-12 rounded-3xl border-2 border-rose-500/10">
      <ExamMode client:load questions={questions} />
    </div>
  </div>
</Layout>