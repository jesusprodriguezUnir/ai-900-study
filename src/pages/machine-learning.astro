---
import Layout from '../layouts/Layout.astro';
import Quiz from '../components/Quiz.vue';

const questions = [
  {
    text: "Tienes datos de transacciones de tarjetas de crédito donde cada transacción está marcada como 'fraude' o 'no fraude'. ¿Qué tipo de aprendizaje es más adecuado?",
    options: ["Supervised Learning (Clasificación)", "Unsupervised Learning", "Reinforcement Learning", "Semi-Supervised Learning"],
    correct: 0,
    explanation: "Cuando tenemos datos etiquetados (fraude/no fraude), usamos aprendizaje supervisado para clasificación."
  },
  {
    text: "Un modelo predice perfectamente en los datos de entrenamiento (99% accuracy) pero solo 55% en datos nuevos. ¿Qué está ocurriendo?",
    options: ["Underfitting", "Good fit", "Overfitting", "El modelo está perfecto"],
    correct: 2,
    explanation: "Overfitting ocurre cuando el modelo memoriza los datos de entrenamiento y no generaliza a datos nuevos."
  },
  {
    text: "Quieres identificar grupos de clientes similares sin saber de antemano cuántos grupos existen. ¿Qué técnica usas?",
    options: ["Clasificación", "Regresión", "Clustering", "Forecasting"],
    correct: 2,
    explanation: "Clustering es una técnica no supervisada para encontrar grupos naturales en los datos."
  },
  {
    text: "En un modelo predictivo de precios de casas, ¿cuál de las siguientes es un 'feature'?",
    options: ["Metros cuadrados", "Precio de la casa", "El modelo entrenado", "La precisión del modelo"],
    correct: 0,
    explanation: "Los features son las variables de entrada (metros cuadrados, habitaciones, etc.) que usamos para predecir el label (precio)."
  },
  {
    text: "Un modelo de ML es demasiado simple y no captura los patrones en los datos. ¿Cómo se llama este problema?",
    options: ["Underfitting", "Overfitting", "Data leakage", "Good fit"],
    correct: 0,
    explanation: "Underfitting ocurre cuando el modelo es demasiado simple para capturar los patrones relevantes."
  },
  {
    text: "¿Cuál de las siguientes opciones permite crear modelos de ML sin escribir código en Azure?",
    options: ["Azure ML Notebooks", "Azure ML Designer", "Azure CLI", "SDK de Python"],
    correct: 1,
    explanation: "Azure ML Designer es una interfaz visual drag-and-drop que permite crear modelos sin código."
  },
  {
    text: "AutoML en Azure ML automatiza todo EXCEPTO:",
    options: ["Selección de algoritmo", "Feature engineering", "Definición del problema de negocio", "Selección de hiperparámetros"],
    correct: 2,
    explanation: "AutoML automatiza la parte técnica, pero tú debes definir qué problema de negocio quieres resolver."
  },
  {
    text: "¿Qué tipo de tarea de ML usarías para predecir la temperatura de los próximos 7 días?",
    options: ["Clasificación", "Clustering", "Regresión (Series Temporales)", "Detección de anomalías"],
    correct: 2,
    explanation: "Predecir valores continuos (temperatura) es una tarea de regresión, especialmente cuando implica series temporales."
  },
  {
    text: "En Azure ML, ¿dónde se almacenan los recursos como datasets, modelos y experimentos?",
    options: ["Azure Storage Blob", "Azure SQL Database", "Azure ML Workspace", "Azure Container Registry"],
    correct: 2,
    explanation: "El Workspace es el contenedor principal que organiza todos los recursos de Azure ML."
  },
  {
    text: "¿Cuál es la principal ventaja de AutoML sobre el entrenamiento manual?",
    options: ["Automatiza la selección del mejor algoritmo e hiperparámetros", "Siempre produce modelos más precisos", "No requiere datos de entrenamiento", "Funciona sin conexión a internet"],
    correct: 0,
    explanation: "AutoML prueba múltiples algoritmos y configuraciones automáticamente para encontrar el mejor modelo."
  }
];
---

<Layout title="Machine Learning">
  <div class="max-w-4xl">
    <h1 class="text-3xl font-bold mb-6">Módulo 2: Machine Learning</h1>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Conceptos Fundamentales</h2>

      <div class="prose">
        <h3>Tipos de Aprendizaje</h3>

        <h4>1. Supervised Learning (Aprendizaje Supervisado)</h4>
        <p>El modelo aprende de datos etiquetados (con respuestas correctas).</p>
        <ul>
          <li><strong>Clasificación:</strong> Predecir categorías (spam/no spam)</li>
          <li><strong>Regresión:</strong> Predecir valores continuos (precio)</li>
        </ul>

        <h4>2. Unsupervised Learning (Aprendizaje No Supervisado)</h4>
        <p>El modelo encuentra patrones en datos sin etiquetas.</p>
        <ul>
          <li><strong>Clustering:</strong> Agrupar datos similares</li>
          <li><strong>Reducción de dimensionalidad:</strong> Simplificar datos</li>
        </ul>

        <h4>3. Reinforcement Learning</h4>
        <p>El modelo aprende por prueba y error, recibiendo recompensas o penalizaciones.</p>

        <h3>Problemas Comunes</h3>

        <table>
          <thead>
            <tr>
              <th>Problema</th>
              <th>Descripción</th>
              <th>Solución</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Overfitting</strong></td>
              <td>Modelo muy complejo, memoriza datos</td>
              <td>Regularización, más datos, cross-validation</td>
            </tr>
            <tr>
              <td><strong>Underfitting</strong></td>
              <td>Modelo muy simple, no captura patrones</td>
              <td>Modelo más complejo, más features</td>
            </tr>
          </tbody>
        </table>

        <h3>Conceptos Clave</h3>
        <ul>
          <li><strong>Features:</strong> Variables de entrada</li>
          <li><strong>Label:</strong> Variable a predecir</li>
          <li><strong>Training data:</strong> Datos para entrenar</li>
          <li><strong>Test data:</strong> Datos para evaluar</li>
        </ul>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Azure Machine Learning</h2>

      <div class="prose">
        <h3>Componentes de Azure ML</h3>

        <table>
          <thead>
            <tr>
              <th>Componente</th>
              <th>Descripción</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Workspace</strong></td>
              <td>Contenedor principal que organiza todos los recursos</td>
            </tr>
            <tr>
              <td><strong>Designer</strong></td>
              <td>Interfaz visual para crear modelos sin código</td>
            </tr>
            <tr>
              <td><strong>AutoML</strong></td>
              <td>Automatiza selección de algoritmos e hiperparámetros</td>
            </tr>
            <tr>
              <td><strong>Notebooks</strong></td>
              <td>Entorno de código con Jupyter notebooks</td>
            </tr>
          </tbody>
        </table>

        <h3>Servicios de Azure AI</h3>
        <ul>
          <li><strong>Azure Machine Learning:</strong> Para crear y desplegar modelos personalizados</li>
          <li><strong>Azure AI Studio:</strong> Plataforma unificada para servicios de IA</li>
        </ul>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-4">Quiz de Práctica</h2>
      <Quiz client:load questions={questions} moduleId="machine-learning" />
    </section>
  </div>
</Layout>