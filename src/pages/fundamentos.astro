---
import Layout from '../layouts/Layout.astro';
import Quiz from '../components/Quiz.vue';

const questions = [
  {
    text: "Una empresa de comercio electrónico quiere predecir la demanda de productos para los próximos 3 meses. ¿Qué carga de trabajo debe utilizar?",
    options: ["Anomaly Detection", "Prediction/Forecasting", "Computer Vision", "NLP"],
    correct: 1,
    explanation: "La predicción de demanda es un caso clásico de forecasting, donde se usan datos históricos para predecir valores futuros."
  },
  {
    text: "Un banco necesita detectar transacciones fraudulentas. Las transacciones sospechosas representan solo el 0.05% del total. ¿Qué carga de trabajo es más adecuada?",
    options: ["Anomaly Detection", "Prediction", "Conversational AI", "Computer Vision"],
    correct: 0,
    explanation: "Cuando hay datos muy desbalanceados con pocas instancias de interés (anomalías), Anomaly Detection es la opción correcta."
  },
  {
    text: "Una empresa quiere analisar los tweets de sus clientes para saber si son positivos o negativos. ¿Qué carga de trabajo utiliza?",
    options: ["Computer Vision", "Anomaly Detection", "NLP - Sentiment Analysis", "Prediction"],
    correct: 2,
    explanation: "El análisis de sentimientos es una tarea de NLP que procesa texto para detectar opiniones y emociones."
  },
  {
    text: "Un hotel quiere un chatbot para atender reservas y preguntas frecuentes. ¿Qué carga de trabajo necesita?",
    options: ["NLP", "Computer Vision", "Conversational AI", "Anomaly Detection"],
    correct: 2,
    explanation: "Los chatbots y asistentes virtuales son ejemplos de Conversational AI."
  },
  {
    text: "Para extraer texto de facturas escaneadas, ¿qué carga de trabajo se utiliza?",
    options: ["NLP", "Prediction", "Computer Vision (OCR)", "Conversational AI"],
    correct: 2,
    explanation: "OCR (Optical Character Recognition) es una capacidad de Computer Vision que extrae texto de imágenes."
  },
  {
    text: "Un sistema de IA discrimina por género en las decisiones de contratación. ¿Qué principio se viola?",
    options: ["Transparency", "Fairness", "Privacy", "Reliability"],
    correct: 1,
    explanation: "Fairness (imparcialidad) se viola cuando el sistema discrimina por género u otras características protegidas."
  },
  {
    text: "Una aplicación no informa a los usuarios que utiliza IA para tomar decisiones sobre ellos. ¿Qué principio se viola?",
    options: ["Transparency", "Privacy", "Inclusiveness", "Reliability"],
    correct: 0,
    explanation: "Transparency requiere que los usuarios sepan cuándo interactúan con sistemas de IA."
  },
  {
    text: "Para cumplir con Privacy, ¿cuál práctica es más importante?",
    options: ["Minimizar datos recopilados y obtener consentimiento", "Usar los modelos más precisos", "Incluir múltiples idiomas", "Documentar todas las decisiones técnicas"],
    correct: 0,
    explanation: "Privacy se basa en recopilar solo datos necesarios y obtener consentimiento claro."
  },
  {
    text: "Una empresa implementa IA sin establecer quién es responsable de las decisiones del sistema. ¿Qué principio se viola?",
    options: ["Fairness", "Inclusiveness", "Privacy", "Accountability"],
    correct: 3,
    explanation: "Accountability requiere que haya roles y responsabilidades claras sobre el sistema de IA."
  },
  {
    text: "Para hacer un sistema más inclusivo, ¿cuál acción es más efectiva?",
    options: ["Usar los datos más precisos posibles", "Documentar todas las decisiones", "Diseñar considerando diferentes capacidades y contextos", "Hacer el modelo más complejo"],
    correct: 2,
    explanation: "Inclusiveness significa diseñar para todas las personas, considerando discapacidades, idiomas, y contextos diversos."
  }
];
---

<Layout title="Fundamentos de IA">
  <div class="max-w-4xl">
    <h1 class="text-3xl font-bold mb-6">Módulo 1: Fundamentos de IA</h1>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Cargas de Trabajo de IA</h2>

      <div class="prose">
        <h3>¿Qué es una Carga de Trabajo de IA?</h3>
        <p>Una <strong>carga de trabajo de IA</strong> es un tipo específico de tarea que puede resolverse utilizando técnicas de inteligencia artificial.</p>

        <h3>Tipos de Cargas de Trabajo</h3>

        <h4>1. Prediction / Forecasting</h4>
        <p>Utiliza datos históricos para predecir resultados futuros.</p>
        <ul>
          <li><strong>Cuándo usarla:</strong> Series temporales, predecir valores numéricos</li>
          <li><strong>Ejemplos:</strong> Predecir precios, demanda, temperaturas</li>
          <li><strong>Servicios Azure:</strong> Azure Machine Learning, Azure Synapse Analytics</li>
        </ul>

        <h4>2. Anomaly Detection</h4>
        <p>Identifica patrones inusuales o atípicos en los datos.</p>
        <ul>
          <li><strong>Cuándo usarla:</strong> Datos muy desbalanceados, detección de fraude</li>
          <li><strong>Ejemplos:</strong> Detección de fraude, monitorización de equipos</li>
          <li><strong>Servicios Azure:</strong> Azure Anomaly Detector</li>
        </ul>

        <h4>3. Computer Vision</h4>
        <p>Procesa y analiza imágenes o vídeos.</p>
        <ul>
          <li><strong>Subcategorías:</strong> Image Classification, Object Detection, OCR, Face Detection</li>
          <li><strong>Servicios Azure:</strong> Azure AI Vision, Custom Vision, Face, Form Recognizer</li>
        </ul>

        <h4>4. Natural Language Processing (NLP)</h4>
        <p>Procesa y analiza texto o lenguaje humano.</p>
        <ul>
          <li><strong>Subcategorías:</strong> Sentiment Analysis, Entity Recognition, Translation</li>
          <li><strong>Servicios Azure:</strong> Azure Text Analytics, Translator, Speech</li>
        </ul>

        <h4>5. Conversational AI</h4>
        <p>Crea sistemas que interactúan mediante diálogo.</p>
        <ul>
          <li><strong>Componentes:</strong> Speech Recognition, NLU, Dialog Management, Speech Synthesis</li>
          <li><strong>Servicios Azure:</strong> Azure AI Studio, QnA Maker, Bot Service, LUIS</li>
        </ul>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">IA Responsable</h2>

      <div class="prose">
        <p>La IA Responsable es un enfoque para desarrollar y usar la IA de manera ética y segura. Los principios fundamentales son:</p>

        <h3>Los 6 Principios de IA Responsable</h3>

        <table>
          <thead>
            <tr>
              <th>Principio</th>
              <th>Descripción</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Fairness</strong></td>
              <td>Imparcialidad - El sistema no debe discriminar</td>
            </tr>
            <tr>
              <td><strong>Transparency</strong></td>
              <td>Transparencia - Los usuarios deben saber que interactúan con IA</td>
            </tr>
            <tr>
              <td><strong>Privacy</strong></td>
              <td>Privacidad - Proteger datos personales y obtener consentimiento</td>
            </tr>
            <tr>
              <td><strong>Accountability</strong></td>
              <td>Responsabilidad - Roles claros sobre las decisiones del sistema</td>
            </tr>
            <tr>
              <td><strong>Inclusiveness</strong></td>
              <td>Inclusividad - Diseñar para todas las personas</td>
            </tr>
            <tr>
              <td><strong>Reliability</strong></td>
              <td>Fiabilidad - Probar exhaustivamente y monitorear en producción</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-4">Quiz de Práctica</h2>
      <Quiz client:load questions={questions} moduleId="fundamentos" />
    </section>
  </div>
</Layout>