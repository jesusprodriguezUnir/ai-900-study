---
import Layout from '../layouts/Layout.astro';
import Quiz from '../components/Quiz.vue';
import questions from '../data/questions/computer-vision.json';
---

<Layout title="Computer Vision">
  <div class="max-w-4xl">
    <h1 class="text-3xl font-bold mb-6">Módulo 3: Computer Vision</h1>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">¿Qué es Computer Vision?</h2>

      <div class="prose">
        <p>Computer Vision es el campo de la IA que permite a las máquinas "ver" y entender imágenes y vídeos.</p>

        <h3>Tipos de Tareas</h3>

        <table>
          <thead>
            <tr>
              <th>Tipo</th>
              <th>Descripción</th>
              <th>Ejemplo</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Image Classification</strong></td>
              <td>Clasificar toda la imagen en una categoría</td>
              <td>¿Es un gato o un perro?</td>
            </tr>
            <tr>
              <td><strong>Object Detection</strong></td>
              <td>Encontrar y localizar objetos específicos</td>
              <td>¿Dónde está el perro?</td>
            </tr>
            <tr>
              <td><strong>Semantic Segmentation</strong></td>
              <td>Segmentar por categorías a nivel de píxel</td>
              <td>¿Qué píxeles son calle?</td>
            </tr>
            <tr>
              <td><strong>OCR</strong></td>
              <td>Extraer texto de imágenes</td>
              <td>Leer facturas</td>
            </tr>
            <tr>
              <td><strong>Face Detection</strong></td>
              <td>Detectar y analizar rostros</td>
              <td>Reconocimiento facial</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-semibold mb-4">Servicios de Azure</h2>

      <div class="prose">
        <h3>Azure AI Vision</h3>
        <ul>
          <li>Modelos preentrenados generales</li>
          <li>Analysis de imágenes, detección de objetos, OCR</li>
          <li>No requiere entrenamiento</li>
          <li><strong>Limitación:</strong> No se adapta a dominios específicos</li>
        </ul>

        <h3>Azure Custom Vision</h3>
        <ul>
          <li>Entrenar clasificadores personalizados</li>
          <li>Para dominios específicos</li>
          <li>Exportar modelos a ONNX, TensorFlow, CoreML</li>
          <li>Usar en dispositivos edge</li>
        </ul>

        <h3>Azure Face</h3>
        <ul>
          <li>Detección de rostros</li>
          <li>Verificación de identidad</li>
          <li>Reconocimiento facial</li>
          <li>Detección de emociones</li>
        </ul>

        <h3>Azure Form Recognizer</h3>
        <ul>
          <li>Extraer datos de formularios</li>
          <td>Pares clave-valor</td>
          <li>Facturas, receipts, contratos</li>
          <li>Procesamiento de documentos</li>
        </ul>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold mb-4">Quiz de Práctica</h2>
      <Quiz client:visible questions={questions} moduleId="computer-vision" />
    </section>
  </div>
</Layout>