---
import Layout from '../layouts/Layout.astro';
import Quiz from '../components/Quiz.vue';
import questions from '../data/questions/computer-vision.json';

const visionTasks = [
  {
    title: "Image Classification",
    desc: "Clasifica una imagen completa en una categoría predefinida (ej: ¿perro o gato?).",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>`,
    color: "from-blue-500 to-cyan-500"
  },
  {
    title: "Object Detection",
    desc: "Localiza y etiqueta objetos específicos dentro de una imagen mediante cuadros delimitadores.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9V7a5 5 0 0 1 5-5h2"/><path d="M15 2h2a5 5 0 0 1 5 5v2"/><path d="M22 15v2a5 5 0 0 1-5 5h-2"/><path d="M9 22H7a5 5 0 0 1-5-5v-2"/><rect width="10" height="10" x="7" y="7" rx="2"/></svg>`,
    color: "from-emerald-500 to-teal-500"
  },
  {
    title: "Semantic Segmentation",
    desc: "Clasifica cada píxel de una imagen según a qué objeto pertenece.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v10"/><path d="M18.4 12.1a1 1 0 0 1-.5 1.5l-4.5 2.4a1 1 0 0 1-1.4-1.1V12"/><path d="M5.6 12.1a1 1 0 0 0 .5 1.5l4.5 2.4a1 1 0 0 0 1.4-1.1V12"/><path d="M2 10a10 10 0 0 1 20 0v4a10 10 0 0 1-20 0Z"/></svg>`,
    color: "from-purple-500 to-violet-500"
  },
  {
    title: "OCR",
    desc: "Reconocimiento Óptico de Caracteres para extraer texto impreso o manuscrito.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4a2 2 0 0 1 2-2h2"/><path d="M16 2h2a2 2 0 0 1 2 2v3"/><path d="M20 17v3a2 2 0 0 1-2 2h-2"/><path d="M8 22H6a2 2 0 0 1-2-2v-3"/><path d="M12 8v8"/><path d="M9 12h6"/></svg>`,
    color: "from-orange-500 to-amber-500"
  },
  {
    title: "Face Detection",
    desc: "Detecta rostros humanos y analiza sus atributos (edad, emociones, etc.).",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 22H5a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/><path d="M9 16c.5 1.5 1.5 2 3 2s2.5-.5 3-2"/></svg>`,
    color: "from-rose-500 to-pink-500"
  }
];

const azureVisionServices = [
  { 
    title: "Azure AI Vision", 
    items: ["Modelos pre-entrenados", "Análisis general", "Rápido de implementar"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12c.5 1 .8 2.3.8 3.5a5.5 5.5 0 1 1-11 0c0-1.2.3-2.5.8-3.5"/><path d="M3 12c-.5 1-.8 2.3-.8 3.5a5.5 5.5 0 1 0 11 0c0-1.2-.3-2.5-.8-3.5"/><path d="M12 12c.5 1 .8 2.3.8 3.5a5.5 5.5 0 1 1-11 0c0-1.2.3-2.5.8-3.5"/></svg>`
  },
  { 
    title: "Custom Vision", 
    items: ["Modelos personalizados", "Dominios específicos", "Control sobre el entrenamiento"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8"/><path d="m4.93 4.93 5.66 5.66"/><path d="M2 12h8"/><path d="m4.93 19.07 5.66-5.66"/><path d="M12 22v-8"/><path d="m19.07 19.07-5.66-5.66"/><path d="M22 12h-8"/><path d="m19.07 4.93-5.66 5.66"/></svg>`
  },
  { 
    title: "Azure AI Face", 
    items: ["Reconocimiento facial", "Verificación de identidad", "Análisis de emociones"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2Z"/><path d="M22 12a10 10 0 1 1-20 0 10 10 0 0 1 20 0Z"/><path d="M12 18a6 6 0 0 1-5-2.7"/><path d="M12 18a6 6 0 0 0 5-2.7"/></svg>`
  }
];
---

<Layout title="Computer Vision">
  <div class="space-y-16 pb-20">
    <!-- Hero Section -->
    <header class="relative overflow-hidden rounded-3xl p-8 md:p-12 bg-surface border border-surface-border shadow-sm">
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-emerald-500/10 rounded-full blur-3xl"></div>
      <div class="relative z-10 max-w-2xl">
        <span class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-wider uppercase bg-emerald-500/10 text-emerald-600 rounded-full">
          Módulo 3
        </span>
        <h1 class="text-4xl md:text-5xl font-black mb-6 leading-tight">
          Poder Visual con <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-500">Computer Vision</span>
        </h1>
        <p class="text-lg text-foreground/70 leading-relaxed">
          Explora cómo la IA puede interpretar el mundo visual, desde el reconocimiento de objetos hasta el procesamiento de documentos complejos.
        </p>
      </div>
    </header>

    <!-- Vision Tasks -->
    <section>
      <div class="flex items-center gap-4 mb-8">
        <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <h2 class="text-3xl font-bold">Tareas Principales</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {visionTasks.map(task => (
          <div class="card-premium group">
            <div class={`w-12 h-12 rounded-xl mb-6 flex items-center justify-center bg-gradient-to-br ${task.color} text-white shadow-lg group-hover:scale-110 transition-transform duration-500`}>
              <Fragment set:html={task.icon} />
            </div>
            <h3 class="text-xl font-bold mb-3 group-hover:text-primary transition-colors">{task.title}</h3>
            <p class="text-foreground/60 text-sm leading-relaxed">{task.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Azure Services -->
    <section>
      <div class="flex items-center gap-4 mb-8">
        <div class="w-10 h-10 rounded-lg bg-teal-500/10 flex items-center justify-center text-teal-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>
        <h2 class="text-3xl font-bold">Servicios de Azure</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {azureVisionServices.map(service => (
          <div class="glass p-8 rounded-3xl border border-surface-border relative group hover:border-teal-500/30 transition-all duration-300">
            <div class="text-teal-500 mb-6 group-hover:scale-110 transition-transform duration-300" set:html={service.icon} />
            <h3 class="text-xl font-bold mb-6">{service.title}</h3>
            <ul class="space-y-4">
              {service.items.map(item => (
                <li class="flex items-center gap-3 text-sm text-foreground/70">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-teal-500"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Quiz Section -->
    <section id="quiz" class="pt-10">
      <div class="glass p-8 md:p-12 rounded-3xl border-2 border-emerald-500/10">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
          <div>
            <h2 class="text-3xl font-bold mb-2 text-foreground">Comprueba lo aprendido</h2>
            <p class="text-foreground/60">Pon a prueba tus conocimientos sobre Computer Vision en Azure.</p>
          </div>
          <div class="px-6 py-2 bg-emerald-500/10 text-emerald-600 rounded-full font-bold text-sm border border-emerald-500/20">
            {questions.length} Preguntas
          </div>
        </div>
        
        <Quiz client:visible questions={questions} moduleId="computer-vision" />
      </div>
    </section>
  </div>
</Layout>