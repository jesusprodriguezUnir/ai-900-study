---
import Layout from '../layouts/Layout.astro';

const stats = [
  { label: 'Módulos', value: '5', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>` },
  { label: 'Preguntas', value: '+200', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M12 12h.01"/><path d="M16 12h.01"/><path d="M8 12h.01"/></svg>` },
  { label: 'Examen Real', value: '45m', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>` }
];

const modules = [
  { 
    id: 1,
    title: 'Fundamentos de IA', 
    desc: 'Cargas de trabajo de IA, conceptos de IA responsable y principios éticos esenciales.',
    href: '/fundamentos',
    color: 'from-blue-500 to-cyan-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  },
  { 
    id: 2,
    title: 'Machine Learning', 
    desc: 'Azure Machine Learning, algoritmos, regresión, clasificación y clustering.',
    href: '/machine-learning',
    color: 'from-purple-500 to-indigo-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>`
  },
  { 
    id: 3,
    title: 'Computer Vision', 
    desc: 'Análisis de imágenes, detección de objetos, OCR y reconocimiento facial en Azure.',
    href: '/computer-vision',
    color: 'from-emerald-500 to-teal-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`
  },
  { 
    id: 4,
    title: 'NLP', 
    desc: 'Procesamiento de Lenguaje Natural, análisis de texto, voz y traducción automática.',
    href: '/nlp',
    color: 'from-orange-500 to-amber-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`
  },
  { 
    id: 5,
    title: 'Simulacro de Examen', 
    desc: 'Pon a prueba tus conocimientos con un simulador que replica el examen real.',
    href: '/exam/simulacro',
    color: 'from-rose-500 to-pink-400',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`
  }
];
---

<Layout title="Inicio">
  <div class="space-y-24 pb-20">
    <!-- Hero Section -->
    <section class="relative pt-10">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-black tracking-widest uppercase mb-8 animate-fade-in">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          Actualizado para examen AI-900 2024
        </div>
        <h2 class="text-6xl md:text-7xl font-black mb-8 leading-[1.1] animate-fade-in tracking-tight">
          Domina <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent italic">Azure</span> <br/> AI Fundamentals
        </h2>
        <p class="text-xl text-foreground/60 mb-12 leading-relaxed max-w-2xl animate-fade-in [animation-delay:200ms]">
          La guía definitiva en español para certificar tus conocimientos en Inteligencia Artificial con Microsoft Azure. Interactiva, práctica y diseñada para el éxito.
        </p>
        <div class="flex flex-wrap gap-4 animate-fade-in [animation-delay:400ms]">
          <a href="/fundamentos" class="btn-primary flex items-center gap-3">
            Empezar el curso
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/recursos" class="btn-secondary">Explorar Recursos</a>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-20 animate-fade-in [animation-delay:600ms]">
        {stats.map(stat => (
          <div class="glass p-6 rounded-3xl border border-surface-border flex items-center gap-5 group hover:border-primary/30 transition-all duration-500">
            <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform duration-500" set:html={stat.icon} />
            <div>
              <div class="text-2xl font-black tracking-tight">{stat.value}</div>
              <div class="text-[10px] uppercase tracking-widest text-foreground/40 font-bold">{stat.label}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Modules Grid -->
    <section>
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
        <div>
          <h2 class="text-4xl font-black tracking-tight mb-3">Ruta de Aprendizaje</h2>
          <p class="text-foreground/50 text-lg">Sigue el camino estructurado para dominar todos los dominios del examen.</p>
        </div>
        <div class="px-6 py-2 glass rounded-full text-xs font-bold text-foreground/60">
          5 Pasos para el éxito
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map(module => (
          <a href={module.href} class="card-premium group h-full flex flex-col">
            <div class={`absolute top-0 right-0 w-32 h-32 bg-gradient-to-br ${module.color} opacity-0 group-hover:opacity-10 blur-2xl transition-opacity duration-500`}></div>
            <div class="relative z-10 flex flex-col h-full">
              <div class="flex items-center justify-between mb-8">
                <div class={`w-12 h-12 rounded-xl flex items-center justify-center bg-gradient-to-br ${module.color} text-white shadow-lg group-hover:scale-110 transition-transform duration-500`} set:html={module.icon} />
                <span class="text-xs font-black text-foreground/20 tabular-nums">0{module.id}</span>
              </div>
              <h3 class="text-2xl font-bold mb-4 group-hover:text-primary transition-colors">{module.title}</h3>
              <p class="text-sm text-foreground/60 leading-relaxed mb-8 flex-1">{module.desc}</p>
              
              <div class="flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-widest group-hover:gap-4 transition-all">
                Explorar módulo
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Resources CTA -->
    <section class="relative overflow-hidden rounded-[3rem] border border-primary/20">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-background to-accent/10 -z-10"></div>
      <div class="p-12 md:p-20 text-center max-w-4xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-black mb-6 tracking-tight">¿Listo para el siguiente nivel?</h2>
        <p class="text-lg text-foreground/60 mb-12 leading-relaxed">
          Accede a nuestra biblioteca exclusiva de recursos descargables, guías rápidas y simulacros adicionales para asegurar tu certificación.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/recursos" class="btn-primary inline-flex items-center gap-3">
            Biblioteca de Recursos
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          </a>
        </div>
      </div>
    </section>
  </div>
</Layout>