---
import Layout from '../layouts/Layout.astro';

const stats = [
  { label: 'Módulos', value: '5', icon: '📚' },
  { label: 'Preguntas', value: '+200', icon: '🤖' },
  { label: 'Examen Real', value: '40m', icon: '📝' }
];

const modules = [
  { 
    id: 1,
    title: 'Fundamentos de IA', 
    desc: 'Cargas de trabajo de IA, conceptos de IA responsable y principios éticos.',
    href: '/fundamentos',
    color: 'from-blue-500 to-cyan-400'
  },
  { 
    id: 2,
    title: 'Machine Learning', 
    desc: 'Azure Machine Learning, algoritmos, regresión y clasificación.',
    href: '/machine-learning',
    color: 'from-purple-500 to-indigo-400'
  },
  { 
    id: 3,
    title: 'Computer Vision', 
    desc: 'Visión por computador, análisis de imágenes y detección de objetos.',
    href: '/computer-vision',
    color: 'from-emerald-500 to-teal-400'
  },
  { 
    id: 4,
    title: 'NLP', 
    desc: 'Procesamiento de Lenguaje Natural, análisis de texto y voz.',
    href: '/nlp',
    color: 'from-orange-500 to-amber-400'
  },
  { 
    id: 5,
    title: 'Simulacro de Examen', 
    desc: 'Pon a prueba tus conocimientos con el simulador oficial de 40 preguntas.',
    href: '/exam/simulacro',
    color: 'from-rose-500 to-pink-400'
  }
];
---

<Layout title="Inicio">
  <div class="space-y-20 pb-20">
    <!-- Hero Section -->
    <section class="relative">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold mb-6 animate-slide-up">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          ACTUALIZADO PARA AZURE 2024
        </div>
        <h2 class="text-6xl font-black mb-6 leading-tight animate-slide-up [animation-delay:100ms]">
          Domina <span class="text-primary italic">Azure</span> AI Fundamentals
        </h2>
        <p class="text-xl text-foreground/60 mb-10 leading-relaxed animate-slide-up [animation-delay:200ms]">
          La guía definitiva en español para certificar tus conocimientos en Inteligencia Artificial con Microsoft Azure. Interactiva, práctica y gratuita.
        </p>
        <div class="flex gap-4 animate-slide-up [animation-delay:300ms]">
          <a href="/fundamentos" class="btn-primary flex items-center gap-2">
            Empezar ahora
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/recursos" class="btn-secondary">Explorar Recursos</a>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="grid grid-cols-3 gap-6 mt-16 animate-fade-in [animation-delay:500ms]">
        {stats.map(stat => (
          <div class="glass p-4 rounded-2xl border border-surface-border flex items-center gap-4">
            <span class="text-2xl">{stat.icon}</span>
            <div>
              <div class="text-xl font-bold">{stat.value}</div>
              <div class="text-[10px] uppercase tracking-wider text-foreground/40 font-bold">{stat.label}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Modules Grid -->
    <section>
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold mb-2">Ruta de Aprendizaje</h2>
          <p class="text-foreground/50">Completa todos los módulos para desbloquear el examen final.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {modules.map(module => (
          <a href={module.href} class="card-premium group">
            <div class={`absolute top-0 right-0 w-32 h-32 bg-gradient-to-br ${module.color} opacity-0 group-hover:opacity-10 blur-2xl transition-opacity duration-500`}></div>
            <div class="relative z-10">
              <div class="flex items-start justify-between mb-4">
                <span class="text-xs font-black text-primary/50 tabular-nums">0{module.id}</span>
                <div class="p-2 rounded-lg bg-surface-border/50 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
              <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{module.title}</h3>
              <p class="text-sm text-foreground/60 leading-relaxed">{module.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Resources CTA -->
    <section class="glass p-12 rounded-[2rem] text-center border-primary/20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-accent/5 -z-10"></div>
      <h2 class="text-3xl font-bold mb-4">¿Necesitas material extra?</h2>
      <p class="text-foreground/60 mb-8 max-w-xl mx-auto">
        Descarga guías de estudio en PDF, mapas mentales y acceso a laboratorios prácticos en la sección de recursos.
      </p>
      <a href="/recursos" class="btn-primary inline-flex items-center gap-2">
        Ir a recursos descargables
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
      </a>
    </section>
  </div>
</Layout>