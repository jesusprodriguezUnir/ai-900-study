---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Recursos">
  <div class="max-w-4xl">
    <h2 class="text-3xl font-bold mb-6">Recursos Descargables</h2>
    <p class="text-lg text-[var(--color-text-secondary)] mb-8">
      Materiales de estudio para complementar tu preparación para el examen AI-900.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="resource-card">
        <div class="flex items-center gap-4 mb-4">
          <div class="text-4xl">📅</div>
          <div>
            <h3 class="font-semibold text-lg">Plan de Estudio 4 Semanas</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">Roadmap estructurado</p>
          </div>
        </div>
        <p class="text-sm mb-4">Plan detallado con resúmenes, mapas conceptuales y cronograma de estudio.</p>
        <div class="flex items-center justify-between">
          <span class="text-sm text-[var(--color-text-secondary)]">DOCX • 150 KB</span>
          <a href="/recursos/AI-900_Plan_Estudio_4Semanas.docx" download class="btn-primary text-sm">Descargar</a>
        </div>
      </div>

      <div class="resource-card">
        <div class="flex items-center gap-4 mb-4">
          <div class="text-4xl">📊</div>
          <div>
            <h3 class="font-semibold text-lg">Banco de Preguntas Práctica</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">110 preguntas</p>
          </div>
        </div>
        <p class="text-sm mb-4">110 preguntas divididas por dominio, con dificultad y explicaciones detalladas.</p>
        <div class="flex items-center justify-between">
          <span class="text-sm text-[var(--color-text-secondary)]">XLSX • 85 KB</span>
          <a href="/recursos/AI-900_Preguntas_Practica.xlsx" download class="btn-primary text-sm">Descargar</a>
        </div>
      </div>

      <div class="resource-card">
        <div class="flex items-center gap-4 mb-4">
          <div class="text-4xl">💼</div>
          <div>
            <h3 class="font-semibold text-lg">Casos Prácticos</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">5 casos de industria</p>
          </div>
        </div>
        <p class="text-sm mb-4">Casos reales con decisiones arquitectónicas y soluciones recomendadas.</p>
        <div class="flex items-center justify-between">
          <span class="text-sm text-[var(--color-text-secondary)]">DOCX • 200 KB</span>
          <a href="/recursos/AI-900_Casos_Practicos.docx" download class="btn-primary text-sm">Descargar</a>
        </div>
      </div>

      <div class="resource-card">
        <div class="flex items-center gap-4 mb-4">
          <div class="text-4xl">📖</div>
          <div>
            <h3 class="font-semibold text-lg">Guía de Estudio Official</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">Microsoft Learn</p>
          </div>
        </div>
        <p class="text-sm mb-4">Guía oficial de Microsoft Learn para el examen AI-900.</p>
        <div class="flex items-center justify-between">
          <span class="text-sm text-[var(--color-text-secondary)]">PDF • 2.5 MB</span>
          <a href="https://learn.microsoft.com/es-es/certifications/exams/ai-900/" target="_blank" rel="noopener" class="btn-secondary text-sm">Ver Online</a>
        </div>
      </div>
    </div>

    <section class="mt-12">
      <h3 class="text-2xl font-bold mb-4">Contacto</h3>
      <p class="text-[var(--color-text-secondary)] mb-6">
        Si quieres sugerir mejoras, reportar errores o colaborar en el proyecto, puedes contactarme por estos canales.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="mailto:jesusprodriguez@gmail.com" class="block p-4 border-2 border-[var(--color-border)] rounded-lg hover:border-primary transition-colors">
          <p class="text-xs text-primary font-semibold uppercase tracking-wider mb-1">Email</p>
          <p class="font-medium break-all">jesusprodriguez@gmail.com</p>
        </a>

        <a href="https://wa.me/34670402450" target="_blank" rel="noopener" class="block p-4 border-2 border-[var(--color-border)] rounded-lg hover:border-primary transition-colors">
          <p class="text-xs text-primary font-semibold uppercase tracking-wider mb-1">WhatsApp</p>
          <p class="font-medium">+34 670 40 24 50</p>
        </a>

        <a href="https://www.linkedin.com/in/jes%C3%BAs-pedro-rodr%C3%ADguez-castro" target="_blank" rel="noopener" class="block p-4 border-2 border-[var(--color-border)] rounded-lg hover:border-primary transition-colors">
          <p class="text-xs text-primary font-semibold uppercase tracking-wider mb-1">LinkedIn</p>
          <p class="font-medium">/in/jesús-pedro-rodríguez-castro</p>
        </a>

        <a href="https://github.com/jesusprodriguezUnir" target="_blank" rel="noopener" class="block p-4 border-2 border-[var(--color-border)] rounded-lg hover:border-primary transition-colors">
          <p class="text-xs text-primary font-semibold uppercase tracking-wider mb-1">GitHub</p>
          <p class="font-medium">@jesusprodriguezUnir</p>
        </a>
      </div>
    </section>
  </div>
</Layout>