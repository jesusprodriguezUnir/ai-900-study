---
import Layout from '../layouts/Layout.astro';

const resources = [
  {
    title: "Plan de Estudio 4 Semanas",
    type: "DOCX",
    size: "150 KB",
    desc: "Hoja de ruta estructurada con resúmenes diarios, mapas conceptuales y cronograma para optimizar tu tiempo.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>`,
    color: "bg-blue-500",
    href: "/recursos/AI-900_Plan_Estudio_4Semanas.docx"
  },
  {
    title: "Banco de Preguntas Práctica",
    type: "XLSX",
    size: "85 KB",
    desc: "Colección de 110 preguntas tipo examen divididas por dominio, con explicaciones detalladas y niveles de dificultad.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>`,
    color: "bg-emerald-500",
    href: "/recursos/AI-900_Preguntas_Practica.xlsx"
  },
  {
    title: "Casos Prácticos de Industria",
    type: "DOCX",
    size: "200 KB",
    desc: "Análisis de 5 escenarios reales donde se aplican servicios de Azure AI para resolver problemas de negocio.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>`,
    color: "bg-purple-500",
    href: "/recursos/AI-900_Casos_Practicos.docx"
  },
  {
    title: "Guía de Estudio Oficial",
    type: "PDF",
    size: "Microsoft Learn",
    desc: "Enlace directo a la documentación oficial y rutas de aprendizaje de Microsoft para el examen AI-900.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    color: "bg-orange-500",
    href: "https://learn.microsoft.com/es-es/certifications/exams/ai-900/",
    external: true
  }
];

const videoResources = [
  {
    title: "Curso Completo AI-900",
    duration: "3h 15m",
    author: "FreeCodeCamp",
    desc: "Excelente repaso detallado de todos los dominios del examen en una sola sesión.",
    url: "https://www.youtube.com/watch?v=ysPbXH0LpIE",
    thumbnail: "https://img.youtube.com/vi/ysPbXH0LpIE/maxresdefault.jpg"
  },
  {
    title: "Azure AI Fundamentals en 60 min",
    duration: "58m",
    author: "John Savill",
    desc: "Repaso intensivo de conceptos clave justo antes del examen.",
    url: "https://www.youtube.com/watch?v=OfUn6HjwXhI",
    thumbnail: "https://img.youtube.com/vi/OfUn6HjwXhI/maxresdefault.jpg"
  }
];

---

<Layout title="Recursos">
  <div class="space-y-16 pb-20">
    <!-- Hero Section -->
    <header class="relative overflow-hidden rounded-3xl p-8 md:p-12 bg-surface border border-surface-border shadow-sm">
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="relative z-10 max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-black mb-6 leading-tight">
          Biblioteca de <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Recursos</span>
        </h1>
        <p class="text-lg text-foreground/70 leading-relaxed">
          Todo el material necesario para complementar tu formación. Descarga guías, bancos de preguntas y casos prácticos diseñados por expertos.
        </p>
      </div>
    </header>

    <!-- Resources Grid -->
    <section>
      <div class="flex items-center gap-4 mb-8">
        <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        </div>
        <h2 class="text-3xl font-bold">Documentos y Guías</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {resources.map(res => (
          <div class="card-premium flex flex-col group">
            <div class="flex items-start justify-between mb-6">
              <div class={`w-12 h-12 rounded-xl flex items-center justify-center ${res.color} text-white shadow-lg group-hover:scale-110 transition-transform duration-500`}>
                <Fragment set:html={res.icon} />
              </div>
              <span class="px-3 py-1 bg-surface-border/50 text-[10px] font-bold rounded-full border border-surface-border">
                {res.type} • {res.size}
              </span>
            </div>
            
            <h3 class="text-xl font-bold mb-3 group-hover:text-primary transition-colors">{res.title}</h3>
            <p class="text-sm text-foreground/60 leading-relaxed mb-8 flex-1">
              {res.desc}
            </p>
            
            <a 
              href={res.href} 
              download={!res.external}
              target={res.external ? "_blank" : undefined}
              class={`w-full py-3 rounded-xl font-bold text-sm text-center transition-all duration-300 flex items-center justify-center gap-2 ${
                res.external 
                  ? "bg-surface border border-surface-border hover:bg-surface-border/50" 
                  : "bg-primary text-white hover:shadow-lg hover:shadow-primary/25"
              }`}
            >
              {res.external ? (
                <>
                  Ver Online
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                </>
              ) : (
                <>
                  Descargar Recurso
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                </>
              )}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- Video Section -->
    <section>
      <div class="flex items-center gap-4 mb-8">
        <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center text-red-600">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>
        </div>
        <h2 class="text-3xl font-bold">Videos Recomendados</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {videoResources.map(video => (
          <a href={video.url} target="_blank" rel="noopener" class="group block overflow-hidden rounded-[2rem] bg-surface border border-surface-border hover:border-red-500/30 transition-all duration-300 hover:shadow-2xl hover:shadow-red-500/5">
            <div class="relative aspect-video overflow-hidden">
              <img src={video.thumbnail} alt={video.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="w-16 h-16 rounded-full bg-red-600 flex items-center justify-center text-white shadow-xl transform scale-75 group-hover:scale-100 transition-transform duration-500">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="m7 4 12 8-12 8V4z"/></svg>
                </div>
              </div>
              <div class="absolute bottom-4 right-4 px-2 py-1 bg-black/80 text-white text-[10px] font-bold rounded">
                {video.duration}
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-red-500/10 text-red-600 text-[10px] font-bold rounded uppercase tracking-wider">{video.author}</span>
              </div>
              <h3 class="text-xl font-bold mb-2 group-hover:text-red-600 transition-colors">{video.title}</h3>
              <p class="text-sm text-foreground/50 leading-relaxed">{video.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Extra Help CTA -->
    <section class="glass p-10 md:p-16 rounded-[3rem] border border-accent/20 relative overflow-hidden text-center">
      <div class="absolute top-0 right-0 p-12 opacity-5 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </div>
      <h2 class="text-3xl font-bold mb-6">¿Dudas o sugerencias?</h2>
      <p class="text-lg text-foreground/60 mb-10 max-w-2xl mx-auto">
        Si crees que falta algún recurso o tienes dudas sobre el contenido, no dudes en contactarme. Estoy aquí para ayudarte a aprobar tu examen.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="mailto:jesusprodriguez@gmail.com" class="btn-primary">Enviar Email</a>
        <a href="https://wa.me/34670402450" target="_blank" class="btn-secondary">WhatsApp Directo</a>
      </div>
    </section>
  </div>
</Layout>